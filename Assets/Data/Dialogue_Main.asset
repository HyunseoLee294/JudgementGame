    text: "\uC548\uB155."
  - startTime: 2.26
    speaker: A
    text: "\uD560 \uB9D0 \uC788\uC5B4?"
  - startTime: 3.75
    speaker: B
    text: "\uC544\uB2C8."
  - startTime: 4.78
    speaker: A
    text: "\uC815\uB9D0?"
  - startTime: 5.92
    speaker: B
    text: "\uC65C \uADF8\uB798, \uAC11\uC790\uAE30."
  - startTime: 8.17
    speaker: A
    text: "\uADF8\uAC8C \uD560 \uB9D0\uC774\uC57C?"
  - startTime: 10
    speaker: B
    text: "\uADF8\uB9CC \uD574!"
  - startTime: 11.17
    speaker: A
    text: "\uADF8\uB798, \uBBF8\uC548."
  - startTime: 12.86
    speaker: B
    text: "...\uBC25\uC740 \uBA39\uC5C8\uC5B4?"
