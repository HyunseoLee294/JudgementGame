    speaker: A
    text: "\uBABB \uBA39\uC5C8\uC5B4."
  - startTime: 15.84
    speaker: B
    text: "\uAC19\uC774 \uBA39\uC744\uB798?"
  - startTime: 17.33
    speaker: A
    text: "\uC544\uB2C8, \uC548 \uBC30\uACE0\uD30C."
  - startTime: 19.56
    speaker: B
    text: "...\uADF8\uB798\uB3C4 \uBA39\uC5B4."
  - startTime: 20.94
    speaker: A
    text: "\uC9C0\uAE08 \uBA87 \uC2DC\uC778\uC9C0 \uC54C\uC544?"
  - startTime: 23.18
    speaker: B
    text: "\uBC25\uC740 \uCC59\uACA8\uBA39\uC5B4\uC57C\uC9C0."
  - startTime: 25.26
    speaker: A
    text: "\uB410\uC5B4."
  - startTime: 26.36
    speaker: A
    text: "\uB0B4\uAC00 \uBB58 \uC783\uC5B4\uBC84\uB838\uC5B4."
