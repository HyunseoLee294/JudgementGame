  m_Script: {fileID: 11500000, guid: c492910a161413544bc1be30c13d5787, type: 3}
  m_Name: JudgeDialogue
  m_EditorClassIdentifier: Assembly-CSharp::JudgeDialogueData
  introLines:
  - "\uC2E0\uC785, \uACAC\uC2B5 \uD310\uAD00\uC774 \uB41C \uAC78 \uCD95\uD558\uD574."
  - "\uC0AC\uD6C4\uC138\uACC4 \uD310\uAD00\uC740 \uC77C\uBC18\uC801\uC778 \uD310\uC0AC\uC640\uB294
    \uB2E4\uB974\uC9C0."
  - "\uBC95\uC774 \uC544\uB2C8\uB77C \uC790\uB124\uB9CC\uC758 \uC7A3\uB300\uB85C
    \uD310\uACB0\uC744 \uB0B4\uB9AC\uBA74 \uB3FC."
  - "\uC774\uC81C, \uADF8 \uD310\uACB0\uC744 \uC2DC\uBBAC\uB808\uC774\uC158\uC73C\uB85C
    \uC5F0\uC2B5\uD574\uBCF4\uC790\uACE0."
  - "\uC790\uB124 \uCCAB \uC0AC\uAC74\uC774\uB124."
  - "'\uC0AC\uAC74\uBA85: \uB179\uC74C\uAE30'"
  - "'\uD310\uACB0: \uBBF8\uC815'"
  - "\uC790, \uC55E\uC758 \uB179\uC74C\uAE30\uB97C \uD2C0\uC5B4\uBCFC\uAE4C?"
  judgmentLine1: "\uB204\uAC00 \uB354, \uC798\uBABB\uD55C \uC0AC\uB78C \uAC19\uB098?"
  judgmentLine2: "\uB204\uAC00 \uB354 \uC798\uBABB\uD588\uB098? \uD310\uB2E8\uD574\uB77C."
  judgmentLine3: "\uC798\uBABB\uD55C \uC0AC\uB78C\uC744 \uC120\uD0DD\uD574\uB77C."
  judgmentLine4: "\uB9C8\uC9C0\uB9C9 \uD310\uB2E8\uC774\uB124. \uC5B4\uB5A4 \uC0AC\uB78C\uC744
    \uCC98\uBC8C\uD574\uC57C \uD558\uB098?"
  endingOpening:
  - "\uADF8\uB798, \uC2E0\uC785."
  endingConsistent: "\uC77C\uAD00\uB41C \uD310\uB2E8\uC744 \uD588\uAD70."
  endingLastSwitch: "\uB9C8\uC9C0\uB9C9\uC5D0 \uD310\uB2E8\uC774 \uD754\uB4E4\uB838\uAD70."
  endingMiddleSwitch: "\uC911\uAC04\uC5D0 \uD310\uB2E8\uC744 \uBC14\uAFE8\uAD70."
  endingFirstSwitch: "\uCC98\uC74C\uC5D0\uB294 \uD754\uB4E4\uB838\uAD70."
  endingManyChanges: "\uD310\uB2E8\uC5D0 \uBCC0\uD654\uAC00 \uB9CE\uC558\uAD70."
  endingClosing:
  - "\uC774\uBC88 \uD6C8\uB828, \uC218\uACE0\uD588\uC5B4."
  - "\uD310\uB2E8\uC774\uB780 \uAC74, \uC5B8\uC81C\uB098 \uBD80\uC871\uD55C \uC815\uBCF4
    \uC18D\uC5D0\uC11C \uB0B4\uB9AC\uB294 \uAC70\uC57C."
  - "\uB2E4\uC74C\uC5D0\uB294 \uB354 \uB098\uC740 \uD310\uACB0\uC744 \uB0B4\uB9AC\uAE38."
  - "\uC544, \uADF8\uB798\uC11C \uC9C4\uC9DC \uD310\uACB0\uC740 \uC5B4\uB5BB\uAC8C
    \uB098\uC654\uB0D0\uACE0?"
  - "\uBBF8\uC815, \uC774\uB77C\uB124."
